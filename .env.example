# EmailJS Configuration
# Get these from https://www.emailjs.com/
NUXT_PUBLIC_EMAILJS_SERVICE_ID=your_service_id
NUXT_PUBLIC_EMAILJS_TEMPLATE_ID=your_template_id
NUXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_public_key

# Site URL (for sitemap and canonical URLs)
NUXT_PUBLIC_SITE_URL=https://vuongphan.dev

# Google Ads conversion tracking (optional; leave blank to disable gtag).
# From Google Ads > Tools > Conversions > New conversion action > Website.
# adsId looks like AW-123456789; the labels look like AbC-D_efGH12iJkLmN.
NUXT_PUBLIC_GTAG_ADS_ID=
NUXT_PUBLIC_GTAG_FORM_LABEL=
NUXT_PUBLIC_GTAG_UPWORK_LABEL=
